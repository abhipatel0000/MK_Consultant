# ============================================================
# MK Consultant Backend — Environment Variables Template
# Copy this to .env and fill in your values.
# NEVER commit the actual .env file to git.
# ============================================================

# Server
NODE_ENV=production
PORT=5000
TRUST_PROXY=1

# Database (use Railway MySQL service variables)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Session (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# CORS — set to your Vercel frontend URL in production
# e.g. https://mk-consultant.vercel.app
ALLOWED_ORIGIN=

# Default Admin Account (created on first boot if not already in DB)
ADMIN_EMAIL=admin@mkconsultant.in
INITIAL_ADMIN_PASSWORD=ChangeMe@123!
